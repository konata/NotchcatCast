<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone"
        app:resize_mode="fit"
        app:shutter_background_color="@android:color/black"
        app:use_controller="false" />

    <SurfaceView
        android:id="@+id/mirror_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone" />

    <View
        android:id="@+id/idle_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/idle_background" />

    <LinearLayout
        android:id="@+id/idle_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="64dp"
        android:paddingVertical="72dp">

        <LinearLayout
            android:id="@+id/landing_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="52dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/status_icon"
                android:layout_width="152dp"
                android:layout_height="152dp"
                android:background="@drawable/icon_background"
                android:contentDescription="@string/application_name"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cat_foreground" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/application_name"
                android:textColor="#FFF8F1"
                android:textSize="50sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_state"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/status_pill"
                android:gravity="center"
                android:minWidth="138dp"
                android:paddingHorizontal="22dp"
                android:textColor="#FFF8F1"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/landing_caption"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="@string/landing_caption"
                android:textColor="#99E7DDD1"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/permission_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/permission_button"
                android:clickable="true"
                android:ellipsize="end"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:minHeight="62dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="10dp"
                android:text="@string/permission_button_text"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_panel"
            android:layout_width="420dp"
            android:layout_height="wrap_content"
            android:background="@drawable/status_panel"
            android:orientation="vertical"
            android:paddingHorizontal="30dp"
            android:paddingVertical="28dp">

            <TextView
                android:id="@+id/status_panel_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_panel_title"
                android:textColor="#FFF8F1"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_panel_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/status_panel_subtitle"
                android:textColor="#8FE7DDD1"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/status_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">

                <LinearLayout style="@style/StatusRow">
                    <TextView
                        style="@style/StatusLabel"
                        android:text="@string/status_wifi_label" />
                    <TextView
                        android:id="@+id/status_wifi_value"
                        style="@style/StatusValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatusRow">
                    <TextView
                        style="@style/StatusLabel"
                        android:text="@string/status_address_label" />
                    <TextView
                        android:id="@+id/status_address_value"
                        style="@style/StatusValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatusRow">
                    <TextView
                        style="@style/StatusLabel"
                        android:text="@string/status_service_label" />
                    <TextView
                        android:id="@+id/status_service_value"
                        style="@style/StatusValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatusRow">
                    <TextView
                        style="@style/StatusLabel"
                        android:text="@string/status_multicast_label" />
                    <TextView
                        android:id="@+id/status_multicast_value"
                        style="@style/StatusValue" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/status_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/status_error"
                android:lineSpacingExtra="3dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="#FFFFE7DD"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="56dp"
        android:layout_marginBottom="38dp"
        android:alpha="0"
        android:background="@drawable/control_bar"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_state_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/control_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="#FFD8DEE6"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/control_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:indeterminateTint="@android:color/white"
            android:max="10000"
            android:progress="0"
            android:progressBackgroundTint="#553D454D"
            android:progressTint="@android:color/white"
            android:secondaryProgress="0" />
    </LinearLayout>
</FrameLayout>
