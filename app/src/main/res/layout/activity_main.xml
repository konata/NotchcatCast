<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone"
        app:resize_mode="fit"
        app:shutter_background_color="@android:color/black"
        app:use_controller="false" />

    <SurfaceView
        android:id="@+id/mirror_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone" />

    <View
        android:id="@+id/idle_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/idle_background" />

    <LinearLayout
        android:id="@+id/idle_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="64dp"
        android:paddingVertical="56dp">

        <!-- Left Column: Brand Column -->
        <LinearLayout
            android:id="@+id/landing_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="64dp"
            android:layout_weight="5"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/brand_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/mangmang_frame_background"
                    android:contentDescription="@string/application_name"
                    android:padding="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_cat_pixel_sharp" />

                <LinearLayout
                    android:id="@+id/brand_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="36dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/application_name"
                        android:textColor="#FFFDF9"
                        android:textSize="52sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/status_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/application_subtitle"
                        android:textColor="#A2BDCE"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/status_state"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/status_state_background"
                        android:drawableStart="@drawable/ic_status_dot"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="16dp"
                        android:textColor="#FFFDF9"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/landing_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:lineSpacingExtra="4dp"
                android:includeFontPadding="false"
                android:text="@string/landing_caption"
                android:textColor="#80C5DBEC"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- Right Column: Status/Info Dashboard Column -->
        <LinearLayout
            android:id="@+id/status_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:orientation="vertical">

            <!-- Card 1 (Wi-Fi) -->
            <LinearLayout
                android:id="@+id/card_wifi"
                style="@style/CardContainer">

                <ImageView
                    style="@style/CardIcon"
                    android:src="@drawable/ic_wifi"
                    android:tint="#A2BDCE" />

                <LinearLayout style="@style/CardTextStack">
                    <TextView
                        style="@style/CardLabel"
                        android:text="@string/status_wifi_card_label" />
                    <TextView
                        android:id="@+id/status_wifi_value"
                        style="@style/CardValue" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card 2 (IP Address) -->
            <LinearLayout
                android:id="@+id/card_address"
                style="@style/CardContainer">

                <ImageView
                    style="@style/CardIcon"
                    android:src="@drawable/ic_network"
                    android:tint="#A2BDCE" />

                <LinearLayout style="@style/CardTextStack">
                    <TextView
                        style="@style/CardLabel"
                        android:text="@string/status_address_card_label" />
                    <TextView
                        android:id="@+id/status_address_value"
                        style="@style/CardValue" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card 3 (Action or Guide Card) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp">

                <!-- Guide State (Visible when permissions are set up) -->
                <LinearLayout
                    android:id="@+id/guide_layout"
                    style="@style/CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="0dp"
                    android:focusable="false"
                    android:clickable="false">

                    <ImageView
                        style="@style/CardIcon"
                        android:src="@drawable/ic_cast"
                        android:tint="#A2BDCE" />

                    <LinearLayout style="@style/CardTextStack">
                        <TextView
                            style="@style/CardLabel"
                            android:text="@string/status_guide_card_label" />
                        <TextView
                            style="@style/CardValue"
                            android:text="@string/status_guide_card_value" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Permission Setup State (Visible when permissions are missing) -->
                <LinearLayout
                    android:id="@+id/permission_row"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/permission_button"
                        style="@style/CardContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="0dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:nextFocusDown="@id/permission_button"
                        android:nextFocusLeft="@id/permission_button"
                        android:nextFocusRight="@id/permission_button"
                        android:nextFocusUp="@id/permission_button">

                        <ImageView
                            style="@style/CardIcon"
                            android:src="@drawable/ic_warning"
                            android:tint="#FFE0B2" />

                        <LinearLayout style="@style/CardTextStack">
                            <TextView
                                style="@style/CardLabel"
                                android:text="@string/status_permission_card_label" />
                            <TextView
                                style="@style/CardValue"
                                android:text="@string/status_permission_card_value" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Error Banner -->
            <TextView
                android:id="@+id/status_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/status_error"
                android:lineSpacingExtra="3dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="#FFFFE7DD"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="56dp"
        android:layout_marginBottom="38dp"
        android:alpha="0"
        android:background="@drawable/control_bar"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_state_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/control_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="#FFD8DEE6"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/control_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:indeterminateTint="@android:color/white"
            android:max="10000"
            android:progress="0"
            android:progressBackgroundTint="#553D454D"
            android:progressTint="@android:color/white"
            android:secondaryProgress="0" />
    </LinearLayout>
</FrameLayout>
