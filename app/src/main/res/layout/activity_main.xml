<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone"
        app:resize_mode="fit"
        app:shutter_background_color="@android:color/black"
        app:use_controller="false" />

    <SurfaceView
        android:id="@+id/mirror_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="gone" />

    <View
        android:id="@+id/idle_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/idle_background" />

    <LinearLayout
        android:id="@+id/idle_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="80dp"
        android:paddingVertical="48dp">

        <!-- Left: brand hero -->
        <LinearLayout
            android:id="@+id/landing_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="64dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/status_icon"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/mangmang_frame_background"
                android:contentDescription="@string/application_name"
                android:padding="18dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cat_pixel_sharp" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:includeFontPadding="false"
                android:text="@string/application_name"
                android:textColor="#F4F7F5"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:includeFontPadding="false"
                android:letterSpacing="0.14"
                android:text="@string/application_subtitle"
                android:textColor="#7E8C84"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/status_state"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/status_state_background"
                android:drawableStart="@drawable/ic_status_dot"
                android:drawablePadding="9dp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="18dp"
                android:textColor="#CFEEE0"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/landing_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="5dp"
                android:maxWidth="420dp"
                android:text="@string/landing_caption"
                android:textColor="#6C7A72"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Right: grouped status panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/status_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/status_panel"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <!-- Wi-Fi -->
                <LinearLayout style="@style/PanelRow">

                    <ImageView
                        style="@style/CardIcon"
                        android:src="@drawable/ic_wifi"
                        android:tint="#3DDC97" />

                    <LinearLayout style="@style/CardTextStack">
                        <TextView
                            style="@style/CardLabel"
                            android:text="@string/status_wifi_card_label" />
                        <TextView
                            android:id="@+id/status_wifi_value"
                            style="@style/CardValue" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="28dp"
                    android:background="@drawable/row_divider" />

                <!-- IP Address -->
                <LinearLayout style="@style/PanelRow">

                    <ImageView
                        style="@style/CardIcon"
                        android:src="@drawable/ic_network"
                        android:tint="#3DDC97" />

                    <LinearLayout style="@style/CardTextStack">
                        <TextView
                            style="@style/CardLabel"
                            android:text="@string/status_address_card_label" />
                        <TextView
                            android:id="@+id/status_address_value"
                            style="@style/CardValue" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="28dp"
                    android:background="@drawable/row_divider" />

                <!-- Action: guide or permission -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="84dp">

                    <!-- Guide (permissions granted) -->
                    <LinearLayout
                        android:id="@+id/guide_layout"
                        style="@style/PanelRow"
                        android:layout_height="match_parent"
                        android:clickable="false"
                        android:focusable="false">

                        <ImageView
                            style="@style/CardIcon"
                            android:src="@drawable/ic_cast"
                            android:tint="#3DDC97" />

                        <LinearLayout style="@style/CardTextStack">
                            <TextView
                                style="@style/CardLabel"
                                android:text="@string/status_guide_card_label" />
                            <TextView
                                style="@style/CardValue"
                                android:text="@string/status_guide_card_value" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Permission setup (permissions missing) -->
                    <LinearLayout
                        android:id="@+id/permission_row"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/permission_button"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="14dp"
                            android:layout_marginVertical="8dp"
                            android:background="@drawable/glass_card_background"
                            android:clickable="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp"
                            android:nextFocusDown="@id/permission_button"
                            android:nextFocusLeft="@id/permission_button"
                            android:nextFocusRight="@id/permission_button"
                            android:nextFocusUp="@id/permission_button">

                            <ImageView
                                style="@style/CardIcon"
                                android:src="@drawable/ic_warning"
                                android:tint="#FFC36A" />

                            <LinearLayout style="@style/CardTextStack">
                                <TextView
                                    style="@style/CardLabel"
                                    android:text="@string/status_permission_card_label" />
                                <TextView
                                    style="@style/CardValue"
                                    android:text="@string/status_permission_card_value" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Error banner -->
            <TextView
                android:id="@+id/status_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/status_error"
                android:lineSpacingExtra="3dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="12dp"
                android:textColor="#F2C9C2"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="56dp"
        android:layout_marginBottom="38dp"
        android:alpha="0"
        android:background="@drawable/control_bar"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/control_state_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/control_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="#D8DEE6"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/control_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:indeterminateTint="#3DDC97"
            android:max="10000"
            android:progress="0"
            android:progressBackgroundTint="#553D454D"
            android:progressTint="#3DDC97"
            android:secondaryProgress="0" />
    </LinearLayout>
</FrameLayout>
